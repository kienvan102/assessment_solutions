# Server Configuration
PORT=8080
ENV=development

# Payment Configuration
# Simulates the delay when processing a payment (e.g. 60s, 500ms)
PAYMENT_PROCESSING_DELAY=60s

# Worker Pool Configuration
# Number of concurrent workers processing the queue
WORKER_POOL_SIZE=5

# Code Review Configuration
# Maximum allowed payload size in bytes (1048576 = 1MB)
CODE_REVIEW_MAX_BODY_SIZE=1048576